{
    "name": "ioweb-gr/m1_phpstan_bridge",
    "description": "Generate PHPStan stubs from OpenMage PhpStorm meta files.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "nikic/php-parser": "^5.0",
        "phpstan/phpstan": "^1.12 || ^2.0"
    },
    "autoload": {
        "psr-4": {
            "Ioweb\\M1PhpStanBridge\\": "src/"
        }
    },
    "bin": [
        "bin/generate-stubs"
    ],
    "config": {
        "sort-packages": true
    }
}
